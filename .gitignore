# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.env
.env.local
.env.*.local

# Planning / memory docs — kept locally, not tracked in source control
*.docx

# Source binaries staged for R2 upload (see scripts/upload-sun-v2.mjs).
# Originals are multi-MB; R2 is the authoritative store once uploaded.
assets-to-upload/

# graphify output (generated by /graphify skill)
graphify-out/

# SSR bundle (intermediate, only used by scripts/prerender.mjs)
dist-ssr/

# Test coverage
coverage/

# Google Places API reviews snapshot — regenerated every build via
# scripts/fetch-google-reviews.mjs. Seeded from google-reviews.example.json
# on fresh checkout (via postinstall) so TypeScript imports always resolve.
src/data/google-reviews.json

# robots.txt is regenerated every build by scripts/generate-robots.mjs
# based on VITE_SITE_ENV (staging/production). Keeping a stale committed
# copy would conflict with env-dependent output.
public/robots.txt

# sitemap.xml is regenerated every build by scripts/generate-sitemap.mjs
# from ROUTES + VITE_SITE_URL; same reasoning as robots.txt above.
public/sitemap.xml

# llms.txt manifest for AI crawlers — regenerated every build by
# scripts/generate-llms.mjs. (llms-full.txt is emitted straight to dist/.)
public/llms.txt

