# Copy this file to `.env` (or `.env.local`) and fill in the values.
# All variables must be prefixed with VITE_ to be exposed to the client bundle.

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# Leave blank in non-production environments to skip analytics loading.
VITE_GA_MEASUREMENT_ID=

# Optional: reviews widget embed URL. If unset, the widget is not loaded.
VITE_REVIEWS_WIDGET_SRC=
# Subresource Integrity hash for the reviews widget (required when VITE_REVIEWS_WIDGET_SRC is set).
# Format: sha384-BASE64HASH
VITE_REVIEWS_WIDGET_SRI=

# WhatsApp contact number in international format without + or spaces, e.g. 919079053840
VITE_WHATSAPP_PHONE=919079053840
