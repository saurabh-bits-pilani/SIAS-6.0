{
  "name": "cosmic-guidance-ssr",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:reviews": "node scripts/fetch-google-reviews.mjs",
    "build:robots": "node scripts/generate-robots.mjs",
    "build:sitemap": "node scripts/generate-sitemap.mjs",
    "build:llms": "node scripts/generate-llms.mjs",
    "build:client": "vite build",
    "build:ssr": "vite build --ssr src/entry-server.tsx --outDir dist-ssr",
    "build:prerender": "node scripts/prerender.mjs",
    "build:llms-full": "node scripts/generate-llms-full.mjs",
    "build:blog-manifest": "node scripts/generate-blog-manifest.mjs",
    "build:build-info": "node scripts/generate-build-info.mjs",
    "prebuild": "npm run build:blog-manifest && npm run build:build-info",
    "build": "npm run build:reviews && npm run build:robots && npm run build:sitemap && npm run build:llms && npm run build:client && npm run build:ssr && npm run build:prerender && npm run build:llms-full",
    "postinstall": "node -e \"const fs=require('fs');const p='src/data/google-reviews.json';const e='src/data/google-reviews.example.json';if(!fs.existsSync(p)&&fs.existsSync(e))fs.copyFileSync(e,p);\"",
    "preview": "vite preview",
    "serve": "node server.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@phosphor-icons/react": "^2.1.10",
    "@tabler/icons-react": "^3.41.1",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "doodle.css": "^0.0.2",
    "dotenv": "^17.4.2",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^11.18.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.344.0",
    "mime-types": "^3.0.2",
    "motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.4",
    "react-icons": "^5.6.0",
    "react-marker": "^1.0.1",
    "react-open-doodles": "^1.0.5",
    "react-rough-notation": "^1.0.8",
    "react-router-dom": "^6.26.1",
    "reading-time": "^1.5.0",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.2.0",
    "rough-notation": "^0.5.1",
    "roughjs": "^4.6.6",
    "splitting": "^1.1.0",
    "tailwind-merge": "^3.6.0",
    "vite-plugin-svgr": "^5.2.0",
    "web-vitals": "^5.2.0",
    "yet-another-react-lightbox": "^3.32.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1034.0",
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "express": "^4.19.2",
    "globals": "^15.9.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.4.35",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vitest": "^4.1.4"
  }
}
